{
  "name": "blocks-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "generate:registry": "bun run scripts/generate-registry.ts",
    "generate:registry:verbose": "bun run scripts/generate-registry.ts --verbose",
    "validate:registry": "bun run scripts/generate-registry.ts validate public/r/registry.json",
    "registry:info": "bun run scripts/generate-registry.ts info",
    "generate:markdown": "bun run scripts/generate-markdown.ts ./content/components/",
    "generate:blocks-data": "bun run scripts/generate-blocks-data.ts",
    "generate:rss": "bun run scripts/generate-rss.ts",
    "build": "opennextjs-cloudflare build",
    "build:next": "bun run generate:registry && bun run generate:markdown && bun run generate:blocks-data && bun run generate:rss && next build",
    "generate": "bun run generate:registry && bun run generate:markdown && bun run generate:blocks-data",
    "start": "next start",
    "lint": "bunx ultracite lint",
    "prepare": "simple-git-hooks",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "simple-git-hooks": {
    "commit-msg": "bunx commitlint --edit $1"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@opennextjs/cloudflare": "^1.19.4",
    "@pierre/diffs": "^1.0.10",
    "@pierre/icons": "^0.1.0",
    "@rive-app/react-webgl2": "^4.26.2",
    "@streamdown/cjk": "^1.0.1",
    "@streamdown/code": "^1.0.1",
    "@streamdown/math": "^1.0.1",
    "@streamdown/mermaid": "^1.0.1",
    "@tabler/icons-react": "^3.34.1",
    "@tanstack/react-table": "^8.21.3",
    "@wandry/analytics-sdk": "^1.16.0",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.68",
    "ansi-to-react": "^6.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^14.0.0",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "media-chrome": "^4.17.2",
    "motion": "^12.30.0",
    "nanoid": "^5.1.6",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.1.2",
    "react-accessible-treeview": "^2.11.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.1.2",
    "react-dropzone": "^14.3.8",
    "react-grab": "^0.0.54",
    "react-resizable-panels": "^4.0.0",
    "recharts": "3.8.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.1.0",
    "tailwind-merge": "^3.5.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^20",
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.7",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.12",
    "ts-morph": "^25.0.1",
    "typescript": "^5",
    "ultracite": "5.0.39",
    "wrangler": "^4.85.0"
  },
  "overrides": {
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.7"
  }
}
